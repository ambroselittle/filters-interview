{
  "name": "server",
  "version": "1.0.0",
  "description": "Express server for Loancrate filters interview",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch . --watch ../shared --exec tsx index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "make-borrowers": "tsx ./scripts/makeBorrowersFile.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "author": "Loancrate",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lodash": "^4.17.21",
    "prisma": "^6.0.0",
    "shared": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.2",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
