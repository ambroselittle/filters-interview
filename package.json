{
  "name": "filters-interview",
  "version": "1.0.0",
  "description": "Loancrate filters interview",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=shared --workspace=server --workspace=client",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "format": "prettier --write .",
    "start": "npm run dev",
    "zip": "git archive HEAD -o filters-interview.zip",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server"
  },
  "author": "Loancrate",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
